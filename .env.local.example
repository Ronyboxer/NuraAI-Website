# Supabase — used by the /api/waitlist route (server-side only).
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Settings → API. Never commit `.env.local` (it's git-ignored).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
